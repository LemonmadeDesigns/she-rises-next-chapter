# Stripe Configuration
# Get your keys from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# PayPal Configuration (Optional)
# Get your credentials from https://developer.paypal.com/
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_SECRET=your_paypal_secret_here

# API Configuration
VITE_API_URL=http://localhost:3001/api

# Email Service Configuration (for receipts)
# Example using SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=donations@sherises.org

# Database Configuration (for donation tracking)
DATABASE_URL=your_database_connection_string_here

# Organization Details
VITE_ORG_NAME="She Rises - Safe Haven for Empowerment"
VITE_ORG_EIN="XX-XXXXXXX"
VITE_ORG_ADDRESS="123 Hope Street, Your City, State 12345"